# Required: Google Gemini API Key for the AI services
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Optional: Gemini model override (defaults to gemini-2.5-flash if omitted)
GEMINI_MODEL=gemini-2.5-flash

# Optional: OpenWeatherMap API Key (falls back to simulated weather if omitted)
# OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
